# --- LLM (pick ONE path; no paid Gemini quota needed) ---
#
# A) Free cloud: Groq — https://console.groq.com/ (free API key)
#    GROQ_API_KEY=gsk_...
#    (optional) GROQ_MODEL=llama-3.1-8b-instant
#
# B) Free local: Ollama — https://ollama.com/  then: ollama pull llama3.2
#    LLM_PROVIDER=ollama
#    (optional) OLLAMA_MODEL=llama3.2
#    (optional) OLLAMA_BASE_URL=http://127.0.0.1:11434
#
# C) Google Gemini (needs quota / billing if free tier exhausted)
#    LLM_PROVIDER=gemini
#    GEMINI_API_KEY=
#    GEMINI_MODEL=gemini-2.0-flash

# Redis (optional — off by default for free local testing)
# REDIS_ENABLED=1
# REDIS_URL=redis://127.0.0.1:6379/0

