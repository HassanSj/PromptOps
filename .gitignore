# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# secrets (never commit) — examples stay tracked
.env
.env.local
.env.*.local
backend/.env
engine/.env
!.env.example
!backend/.env.example
!engine/.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python
backend/.venv/
**/__pycache__/
*.py[cod]
*$py.class
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.eggs/
dist/
*.egg

# Go (local builds)
engine/bin/
*.test
*.out

# Terraform / local state (never commit real state)
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
crash.log

# OS / IDE
Thumbs.db
Desktop.ini
.idea/
*.swp
*.swo

# Local distribution build output (legal + docs only; see scripts/create-distribution.mjs)
/distribution/out/
