# Copy to `.env.local` for Next.js (not committed).
#
# Next.js
BACKEND_URL=http://127.0.0.1:8000
NEXT_PUBLIC_ENGINE_WS_URL=ws://127.0.0.1:8080/ws

# Long LLM calls: server-side fetch timeout (ms). Default 15 minutes.
# BACKEND_FETCH_TIMEOUT_MS=900000

# Backend (set in `backend/.env` or your shell — not used by Next directly)
# GEMINI_API_KEY=
# REDIS_ENABLED=0
# REDIS_URL=redis://127.0.0.1:6379/0

# Go engine vars live on the engine process — see `engine/.env.example`

