# Copy to `.env.local` for Next.js (not committed).

# --- Vercel / Next-only (no Python): set these on Vercel Environment Variables ---
GROQ_API_KEY=
# Optional:
# GROQ_MODEL=llama-3.1-8b-instant
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# --- Optional: proxy to FastAPI instead (local or another host) ---
# If GROQ_API_KEY / GEMINI_API_KEY are NOT set, Next.js will call Python when BACKEND_URL is set.
# BACKEND_URL=http://127.0.0.1:8000

# Go engine (browser WebSocket; only when you run the engine)
NEXT_PUBLIC_ENGINE_WS_URL=ws://127.0.0.1:8080/ws

# Long LLM calls when using Python proxy only (ms). Default 15 minutes.
# BACKEND_FETCH_TIMEOUT_MS=900000

# Python backend extras — see `backend/.env.example` (not read by Next inline path)
# REDIS_ENABLED=0
