# Redis (required for queue + drift registry)
# REDIS_URL=redis://127.0.0.1:6379/0

# Terraform CLI
# TERRAFORM_BIN=C:\path\to\terraform.exe

# Security scan before apply (plan-only jobs skip tfsec)
# TFSEC_BIN=tfsec
# SKIP_TFSEC=1

# Persist successful apply workspaces for drift checks (absolute or relative path)
# DRIFT_DATA_DIR=./data/drift

# Drift worker interval (default 30m). Set DRIFT_DISABLED=1 to turn off ticker.
# DRIFT_INTERVAL=30m
# DRIFT_DISABLED=1
